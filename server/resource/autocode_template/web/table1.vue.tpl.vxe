    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}',sortable: true
     ,editRender: { name: 'input', attrs: { placeholder: '请输入{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "richtext" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}',sortable: true
     ,editRender: { name: 'input', attrs: { placeholder: '请输入{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "picture" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}',sortable: true
     ,editRender: { name: 'input', attrs: { placeholder: '请输入{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "video" }}
