    {{- else if eq .FieldType "time.Time" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}', span: 8, itemRender: { name: 'VxeDatePicker', props: { type: 'datetime', placeholder: '请选择{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "float64" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}', span: 8, itemRender: { name: 'VxeInput', props: { type: 'number', min: 1, max: 120, placeholder: '请输入{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "richtext" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}', span: 8, itemRender: { name: 'RichEdit', props: { placeholder: '请输入{{.FieldDesc}}' } } },
