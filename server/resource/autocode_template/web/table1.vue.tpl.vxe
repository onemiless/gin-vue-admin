    {{- else if eq .FieldType "pictures" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}',sortable: true
     ,editRender: { name: 'input', attrs: { placeholder: '请输入{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "file" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}',sortable: true
     ,editRender: { name: 'input', attrs: { placeholder: '请输入{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "json" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}',sortable: true
     ,editRender: { name: 'input', attrs: { placeholder: '请输入{{.FieldDesc}}' } } },
    {{- end }}
    {{- end }}
    ],
    


// 验证规则
editRules: {
    {{- range .Fields }}
            {{- if eq .Require true }}
