    {{- else if eq .FieldType "pictures" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}', span: 8, itemRender: { name: 'SelectImage', props: { multiple: true, placeholder: '请选择{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "file" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}', span: 8, itemRender: { name: 'SelectFile', props: { multiple: true, placeholder: '请选择{{.FieldDesc}}' } } },
    {{- else if eq .FieldType "json" }}
    { field: '{{.FieldJson}}', title: '{{.FieldDesc}}', span: 8, itemRender: { name: 'VxeInput', props: { placeholder: '请输入{{.FieldDesc}}' } } },
    {{- end }}
    {{- end }}
    ]
},
toolbarConfig: {
  buttons: [
